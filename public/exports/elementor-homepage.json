      "header": {
        "eyebrow": "Our Capabilities",
        "eyebrow_color": "#1a6dcc",
        "title": "Four pillars of growth",
        "subtitle": "An integrated approach where creative, marketing, software, and operations work together—not in silos.",
        "alignment": "center",
        "max_width": "768px"
      },
      "content": {
        "type": "card_grid",
        "columns": 2,
        "gap": "1.5rem",
        "cards": [
          {
            "icon": "palette",
            "title": "Creative Studio",
            "subtitle": "Design & Production",
            "description": "Video, motion graphics, brand identity, and visual storytelling that captures attention and communicates your value.",
            "tags": ["Explainer Videos", "Motion Design", "Brand Systems", "UI/UX"],
            "link": "/services/creative",
            "hover_effect": "lift_with_gradient"
          },
          {
            "icon": "trending-up",
            "title": "Marketing Engine",
            "subtitle": "Growth & Demand",
            "description": "B2B marketing strategies, conversion funnels, and performance campaigns that drive measurable pipeline growth.",
            "tags": ["Demand Gen", "Funnels", "SEO/SEM", "Analytics"],
            "link": "/services/marketing",
            "hover_effect": "lift_with_gradient"
          },
          {
            "icon": "code-2",
            "title": "Software & AI",
            "subtitle": "Build & Automate",
            "description": "Custom software, AI integration, workflow automation, and intelligent systems designed for your specific needs.",
            "tags": ["Custom Apps", "AI Tools", "Automation", "APIs"],
            "link": "/services/software",
            "hover_effect": "lift_with_gradient"
          },
          {
            "icon": "settings",
            "title": "Managed Services",
            "subtitle": "Support & Scale",
            "description": "Ongoing digital support, maintenance, and optimization to keep your systems running at peak performance.",
            "tags": ["24/7 Support", "Updates", "Monitoring", "Optimization"],
            "link": "/services/managed",
            "hover_effect": "lift_with_gradient"
          }
        ]
      }
    },

    {
      "id": "how_we_think",
      "type": "content_section",
      "settings": {
        "padding": "8rem 0",
        "background": "transparent"
      },
      "header": {
        "eyebrow": "Our Philosophy",
        "title": "How Zemnas thinks",
        "subtitle": "Our approach is built on principles that guide every project from discovery to delivery.",
        "alignment": "left",
        "max_width": "640px"
      },
      "content": {
        "type": "numbered_list_with_icons",
        "layout": "vertical_timeline",
        "connecting_line": {
          "color": "linear-gradient(180deg, rgba(26, 109, 204, 0.4) 0%, rgba(26, 109, 204, 0.05) 100%)",
          "width": "1px",
          "position": "left"
        },
        "items": [
          {
            "step": "01",
            "icon": "lightbulb",
            "title": "Strategy before execution",
            "description": "Every project begins with understanding your goals, audience, and market. We align every decision with measurable outcomes."
          },
          {
            "step": "02",
            "icon": "target",
            "title": "Design aligned with performance",
            "description": "Beautiful isn't enough. Our creative work is built to convert, engage, and drive the metrics that matter to your business."
          },
          {
            "step": "03",
            "icon": "wrench",
            "title": "Technology with real use cases",
            "description": "We don't build for the sake of innovation. Every tool, system, and integration solves a specific problem you face."
          },
          {
            "step": "04",
            "icon": "handshake",
            "title": "Long-term partnership mindset",
            "description": "We're not here for one project. We build relationships that grow with your business and evolve with your needs."
          }
        ]
      }
    },

    {
      "id": "capability_strip",
      "type": "marquee_section",
      "settings": {
        "padding": "2rem 0",
        "background": "#0f1419",
        "overflow": "hidden"
      },
      "content": {
        "type": "infinite_marquee",
        "speed": "30s",
        "direction": "left",
        "items": [
          "Explainer Videos",
          "Brand Identity",
          "Motion Graphics",
          "UI/UX Design",
          "Demand Generation",
          "Marketing Funnels",
          "SEO/SEM",
          "Custom Software",
          "AI Integration",
          "Workflow Automation",
          "24/7 Support",
          "Performance Optimization"
        ],
        "separator": "•",
        "text_color": "#ffffff",
        "font_size": "0.875rem",
        "font_weight": "500",
        "letter_spacing": "0.1em"
      }
    },

    {
      "id": "trust_section",
      "type": "testimonials_section",
      "settings": {
        "padding": "4rem 0",
        "background": "rgba(241, 244, 249, 0.3)"

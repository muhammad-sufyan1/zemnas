{
  "elementor_export": {
    "version": "3.0",
    "type": "page",
    "page_name": "Homepage",
    "page_title": "Zemnas - Digital Systems That Scale",
    "meta_description": "Creative. Marketing. Software. AI. Four disciplines, one integrated approach—transforming how businesses connect, convert, and scale."
  },

  "page_settings": {
    "template": "full_width",
    "background": "#fafbfc",
    "padding": "0"
  },

  "sections": [
    {
      "id": "hero",
      "type": "hero_section",
      "settings": {
        "min_height": "85vh",
        "padding": "8rem 0",
        "background": "gradient",
        "gradient": "linear-gradient(180deg, #fafbfc 0%, #f1f4f9 100%)",
        "overflow": "hidden"
      },
      "background_elements": [
        {
          "type": "animated_blur_orb",
          "position": "top-left",
          "size": "500px",
          "color": "rgba(26, 109, 204, 0.05)",
          "animation": "pulse_scale",
          "duration": "8s"
        },
        {
          "type": "animated_blur_orb",
          "position": "bottom-right",
          "size": "400px",
          "color": "rgba(241, 244, 249, 1)",
          "animation": "pulse_scale",
          "duration": "10s",
          "delay": "2s"
        }
      ],
      "layout": {
        "type": "two_column",
        "columns": "1fr 1fr",
        "gap": "5rem",
        "align": "center"
      },
      "content": {
        "left_column": {
          "elements": [
            {
              "type": "badge",
              "icon": "pulse_dot",
              "text": "Digital Systems That Scale",
              "background": "rgba(26, 109, 204, 0.1)",
              "text_color": "#1a6dcc",
              "animation": "fade_up",
              "delay": "0s"
            },
            {
              "type": "heading",
              "tag": "h1",
              "content": {
                "line_1": "We build the systems behind",
                "line_2": "ambitious growth.",
                "line_2_color": "#1a6dcc"
              },
              "animation": "fade_up",
              "delay": "0.1s"
            },
            {
              "type": "paragraph",
              "content": "Creative. Marketing. Software. AI. Four disciplines, one integrated approach—transforming how businesses connect, convert, and scale.",
              "font_size": "1.25rem",
              "color": "#4a5568",
              "max_width": "560px",
              "animation": "fade_up",
              "delay": "0.2s"
            },
            {
              "type": "button_group",
              "buttons": [
                {
                  "text": "View Our Work",
                  "url": "/work",
                  "type": "primary",
                  "icon": "arrow-right",
                  "icon_position": "right"
                },
                {
                  "text": "Start a Project",
                  "url": "/contact",
                  "type": "outline",
                  "icon": "play",
                  "icon_position": "left"
                }
              ],
              "animation": "fade_up",
              "delay": "0.3s"
            },
            {
              "type": "trust_signals",
              "title": "Trusted by forward-thinking companies",
              "logos": ["TechCorp", "InnovateLab", "FutureScale"],
              "animation": "fade_in",
              "delay": "0.5s"
            }
          ]
        },
        "right_column": {
          "type": "hero_visual",
          "style": "floating_cards",
          "background": {
            "type": "glassmorphism",
            "background": "rgba(255, 255, 255, 0.6)",
            "backdrop_blur": "24px",
            "border": "1px solid rgba(221, 226, 232, 0.5)",
            "border_radius": "1.5rem"
          },
          "floating_cards": [
            {
              "title": "Creative Studio",
              "icon": "palette",
              "position": "top-left",
              "animation": "float_up_down",
              "duration": "5s"
            },
            {
              "title": "Marketing",
              "icon": "chart-bar",
              "position": "top-right",
              "animation": "float_up_down",
              "duration": "6s",
              "delay": "1s"
            },
            {
              "title": "Software & AI",
              "progress_bar": true,
              "progress_value": "75%",
              "position": "bottom-left",
              "animation": "float_up_down",
              "duration": "7s",
              "delay": "0.5s"
            },
            {
              "title": "Managed",
              "subtitle": "Always-on",
              "position": "bottom-right",
              "animation": "float_up_down",
              "duration": "5.5s",
              "delay": "2s"
            }
          ]
        }
      },
      "scroll_indicator": {
        "type": "mouse_scroll",
        "position": "bottom-center",
        "animation": "bounce"
      }
    },

    {
      "id": "service_pillars",
      "type": "content_section",
      "settings": {
        "padding": "8rem 0",
        "background": "rgba(241, 244, 249, 0.5)"

      "header": {
        "text": "Trusted by forward-thinking companies",
        "alignment": "center"
      },
      "client_logos": ["TechCorp", "InnovateLab", "FutureScale", "DataDriven", "CloudFirst", "AIVentures"],
      "testimonials": {
        "type": "carousel",
        "autoplay": true,
        "interval": "5000ms",
        "items": [
          {
            "quote": "Zemnas transformed our digital presence. Their strategic approach and attention to detail exceeded our expectations.",
            "author": "Sarah Chen",
            "role": "CEO, TechVentures",
            "avatar_initials": "SC"
          },
          {
            "quote": "Working with Zemnas felt like having an in-house team. They understood our vision and delivered beyond what we imagined.",
            "author": "Marcus Johnson",
            "role": "Founder, GrowthLab",
            "avatar_initials": "MJ"
          },
          {
            "quote": "The AI integration they built saved us 40 hours a week. The ROI was immediate and continues to grow.",
            "author": "Elena Rodriguez",
            "role": "COO, DataFlow Inc",
            "avatar_initials": "ER"
          },
          {
            "quote": "From creative to execution, Zemnas delivered a cohesive brand experience that truly resonates with our audience.",
            "author": "David Park",
            "role": "Marketing Director, Elevate",
            "avatar_initials": "DP"
          }
        ]
      }
    },

    {
      "id": "final_cta",
      "type": "cta_section",
      "settings": {
        "padding": "8rem 0",
        "background": "gradient",
        "gradient": "linear-gradient(180deg, rgba(241, 244, 249, 0.5) 0%, rgba(26, 109, 204, 0.05) 50%, rgba(241, 244, 249, 0.5) 100%)"
      },
      "background_elements": [
        {
          "type": "animated_blur_orb",
          "position": "left",
          "size": "384px",
          "color": "rgba(26, 109, 204, 0.05)"
        },
        {
          "type": "animated_blur_orb",
          "position": "right",
          "size": "384px",
          "color": "rgba(26, 109, 204, 0.05)"
